## Shiny Server

```{r}
## Shiny Server

server <- function(input, output) {
  # 1. What does it do: runs simulations and updates plot
  # 2. Inputs: a list of everything the user controls in the UI.
  # 3. Outputs: scatterplot of allele frequency change
  
  simulation_data <- reactive({
    
    ##Eventually the user will get to select all of the basic numbers
    population_size <- input$pop_size
    generations <- input$gens
    brown_frequency <- input$brown
    blue_frequency <- input$blue
    
    ##Green frequency is just the leftover population that brown and blue does not cover.
    green_frequency <- 1 - brown_frequency - blue_frequency
    
    ##Note to the user to make sure the calculations work.
    validate(need(green_frequency >= 0, "Brown + Blue must be ≤ 1"))
    
    ##Created a vector for frequencies to use in functions later on.
    start_frequencies <- c(brown = brown_frequency, blue = blue_frequency, green = green_frequency)

    ##Create generation 0 with start allele frequencies
    allele_counts <- round(start_frequencies * population_size)
    
    ##total = population_size
    difference <- population_size - sum(allele_counts)
    
    if (difference != 0) {
      allele_counts[which.max(allele_counts)] <- 
        allele_counts[which.max(allele_counts)] + difference
    }
    
    ##Create the allele vector
    alleles <- rep(names(allele_counts), times = allele_counts)
    
    ##Shuffle so they’re randomly distributed
    alleles <- sample(alleles)
    
    ##Create dataframe
    generation0 <- data.frame(individual = 1:population_size, allele = alleles)
    
    ##This desides what rows will be deleted.
    pop <- 1:population_size
    bottle_neck <- remove_random_pct(pop)
    
    ##By joining generation0 and bottle_neck the randomly selected rows are removed from the original generation.
    bottleneck_data <- inner_join(generation0, bottle_neck, by = c("individual" = "result")) %>%
      select(-pct_removed)
    
    ##Count each allele to later determine the new frequencies.
    allele_counts_new <- bottleneck_data %>%
      count(allele)
    
    ##The new variables after the bottleneck is finished.
    new_population_size <- nrow(bottleneck_data)
    
    new_brown_frequency <- allele_counts_new %>%
      filter(allele == "brown") %>%
      pull(n)
    
    if (length(new_brown_frequency) == 0) new_brown_frequency <- 0
    
    new_brown_frequency <- new_brown_frequency / new_population_size
    
    ##Calculated the same way as brown frequencies.
    new_blue_frequency <- allele_counts_new %>%
      filter(allele == "blue") %>%
      pull(n)
    
    if (length(new_blue_frequency) == 0) new_blue_frequency <- 0
    
    new_blue_frequency <- new_blue_frequency / new_population_size
    
    ##The remaining alleles must be green.
    new_green_frequency <- 1 - new_brown_frequency - new_blue_frequency
    
    ##Put the new frequencies into a vector to be used in the functions.
    new_start_frequencies <- c(brown = new_brown_frequency, blue = new_blue_frequency, green = new_green_frequency)

    ##Runs the simulations and stores the results in a data frame.
    results <- run_simulations(input$sims, new_population_size, new_start_frequencies, generations)

    list(results = results, new_population_size = new_population_size, generation0 = generation0, bottleneck_data = bottleneck_data)
  })
  
  output$final_table <- renderTable({
    generation0 <- simulation_data()$generation0
    bottleneck_data <- simulation_data()$bottleneck_data
    results <- simulation_data()$results
    new_population_size <- simulation_data()$new_population_size
    
    gen0_counts <- generation0 %>%
      count(allele) %>%
      mutate(generation = "Generation 0", count = n) %>%
      select(generation, allele, count)
    
    bottleneck_counts <- bottleneck_data %>%
      count(allele) %>%
      mutate(generation = "After Bottleneck", count = n) %>%
      select(generation, allele, count)
    
    final_counts <- results %>%
      filter(simulation == max(simulation)) %>%
      filter(generation == max(generation)) %>%
      mutate(count = round(frequency * new_population_size),
             generation = "Final Generation") %>%
      select(generation, allele, count)
    
    bind_rows(gen0_counts, bottleneck_counts, final_counts)
  })
  
  output$drift_plot <- renderPlot({
    results <- simulation_data()$results
    
    ggplot(results, aes(x = generation, y = frequency, color = allele)) +
      stat_summary(fun = mean, geom = "line", linewidth = 1) +
      scale_color_manual(values = c(
        brown = "brown",
        blue = "blue",
        green = "green"
      )) +
      labs(
        title = "Average Genetic Drift Over Simulations",
        x = "Generation",
        y = "Frequency"
      )
  })
}
```
